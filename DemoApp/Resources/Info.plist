<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>한톡</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- 연락처 권한: 친구 찾기 시점에만 요청됨 -->
	<key>NSContactsUsageDescription</key>
	<string>연락처에서 한톡을 쓰는 친구를 찾기 위해 사용해요. 전화번호 원본은 서버로 전송되지 않고, 암호화된 해시만 대조합니다.</string>

	<!-- ATT: requestsAppTracking을 켠 경우에만 실제로 요청됨.
	     추적 SDK를 넣지 않을 거라면 이 키와 함께 requestsAppTracking=false 유지 -->
	<key>NSUserTrackingUsageDescription</key>
	<string>맞춤 콘텐츠 제공을 위해 앱 추적 권한을 사용합니다.</string>

	<!-- 푸시 백그라운드 수신 (Firebase 모드) -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
