{
  "sourceLanguage": "ko",
  "version": "1.0",
  "strings": {
    "취소": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャンセル"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "取消"
          }
        }
      }
    },
    "확인": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "OK"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "OK"
          }
        },
        "zh-Hans": {
          "stringUnit": {
