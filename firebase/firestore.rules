rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 가입자 디렉터리: 로그인한 사용자는 조회 가능(친구 매칭), 본인 문서만 쓰기
    match /users/{userID} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Phase 2: request.auth.uid 매핑 강화
    }

    // 임티샵 라이선스: 앱(appId)별 옵션 결제 상태 — 읽기만 공개, 쓰기는 운영자 전용
    match /licenses/{appID} {
      allow read: if request.auth != null;
      allow write: if false; // 운영자가 콘솔/Admin SDK로만 발급
    }

    // 이모티콘 갤러리: "사용(읽기)"은 모든 앱 기본 제공.
    // "업로드(생성)"는 유료 옵션 — 요청에 담긴 appId의 라이선스를 서버에서 확인.
    // (UI 숨김은 1차 방어일 뿐, 진짜 강제는 여기서)
    match /emoticons/{emoticonID} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.appID is string
        && get(/databases/$(database)/documents/licenses/$(request.resource.data.appID))
             .data.uploadEnabled == true;
      // 수정/삭제는 Phase 3에서 크리에이터 본인 검증과 함께 열 예정
      allow update, delete: if false;
    }

    // 신고: 로그인 사용자가 생성(접수)만. 읽기는 운영자(커스텀 클레임)만.
    match /reports/{reportID} {
      allow create: if request.auth != null;
      allow read: if request.auth.token.admin == true;
      allow update, delete: if false;
    }
    // 정지 목록: 운영자만 읽기/쓰기 (클라 앱은 접근 불가, Cloud Function 권장)
    match /suspensions/{userID} {
      allow read, write: if request.auth.token.admin == true;
    }

    // 프로필: 로그인 사용자 읽기(친구 프로필 보기), 쓰기는 본인만
    // Phase 2: userID를 auth.uid와 매핑해 본인만 쓰도록 강화
    match /profiles/{userID} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 공지사항 / FAQ: 읽기는 전체 공개, 쓰기는 서버(Admin SDK/Function)만
    // 앱은 관리자여도 클라이언트에서 직접 쓰지 않고 Cloud Function을 거친다.
    match /support/{channel}/posts/{postID} {
      allow read: if true;
      allow write: if false;
    }
    // 콘텐츠 버전 (경량 조회용 — 앱이 자주 확인해도 저렴)
    match /support/{channel} {
      allow read: if true;
      allow write: if false;
    }

    // 우편함: 발신(생성)은 로그인 사용자 누구나, 읽기/삭제(ack)는 수신자 본인만
    match /mailboxes/{recipientID}/envelopes/{envelopeID} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null;
      // update는 retain 모드의 delivered 표시(ack)에만 사용됨
      // Phase 2: recipientID를 auth uid와 매핑해 본인만 읽도록 강화
      allow update: if request.auth != null;
    }
  }
}
